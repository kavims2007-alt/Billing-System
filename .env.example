# Supabase configuration for authentication.
# Copy this file to ".env" and fill in the values from your Supabase project:
#   Supabase Dashboard -> Project Settings -> API
#
# Both values are safe to expose in the browser (the anon key is a public,
# row-level-security-scoped key). Never put the service_role key here.
#
# While these are unset, the app falls back to the built-in localStorage auth,
# so login/register keep working locally without Supabase.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
